# Copy to .env.local for local dev.

# SQLite for local dev. Switch to "postgresql://..." in production.
DATABASE_URL="file:./dev.db"

# Long-lived: signs the auth cookie. Rotate per environment.
JWT_SECRET="change-me-to-a-long-random-string"

# Must match SIGNALING_SECRET on the signaling server.
SIGNALING_SECRET="dev-signaling-secret-change-me"

# Public URL the browser uses to reach the signaling server.
NEXT_PUBLIC_SIGNALING_URL="ws://localhost:8787"

# Optional STUN/TURN. Public Google STUN works for most networks; add TURN for
# strict NAT. Format: comma-separated URIs, optionally followed by | username | credential.
# Example: "stun:stun.l.google.com:19302,turn:turn.example.com:3478|user|pass"
NEXT_PUBLIC_ICE_SERVERS="stun:stun.l.google.com:19302"
