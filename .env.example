# Copy to .env.local for local dev.

# ---- Database ----
# SQLite for local dev. Switch to "postgresql://..." in production.
DATABASE_URL="file:./dev.db"

# ---- Secrets (rotate per environment) ----
# Signs the auth cookie.
JWT_SECRET="change-me-to-a-long-random-string"
# Must match SIGNALING_SECRET on the signaling server.
SIGNALING_SECRET="dev-signaling-secret-change-me"
# Shared with coturn (static-auth-secret in turnserver.conf). Required for
# /api/turn-credentials to work; until set, that endpoint returns 503.
TURN_SECRET=""

# ---- Public origin ----
# Used to build links in outbound emails. No trailing slash.
APP_BASE_URL="http://localhost:3000"

# ---- Email (verification, password reset) ----
# Leave RESEND_API_KEY blank in dev — outbound mail is logged to the dev server's
# stdout instead, so you can copy the verification link by hand.
RESEND_API_KEY=""
EMAIL_FROM="Remotely <no-reply@example.com>"

# ---- WebRTC ICE ----
# Public URL the browser uses to reach the signaling server.
NEXT_PUBLIC_SIGNALING_URL="ws://localhost:8787"
# Comma-separated STUN URIs (no credentials).
NEXT_PUBLIC_STUN_URIS="stun:stun.l.google.com:19302"
# Comma-separated TURN URIs (no credentials baked in — those are issued
# per-session by /api/turn-credentials).
# Example: "turn:turn.example.com:3478,turns:turn.example.com:5349"
NEXT_PUBLIC_TURN_URIS=""

# ---- Rate limiting (production) ----
# Leave both blank in dev — an in-memory limiter is used as a fallback.
# In production set both to switch to Upstash Redis REST.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ---- Crash reporting (optional) ----
# Get a DSN from sentry.io. Leave blank to disable.
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
